generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  LOBBY
  QUESTION
  REVEAL
  LEADERBOARD
  WRITING
  ENDED
}

enum GameKind {
  QUIZ
  STORY
}

model Quiz {
  id          String     @id @default(cuid())
  title       String
  description String?
  department  String?    @unique
  icon        String?
  difficulty  String?
  createdAt   DateTime   @default(now())
  questions   Question[]
  games       Game[]
}

model Question {
  id           String        @id @default(cuid())
  quizId       String
  quiz         Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order        Int
  text         String
  explanation  String?
  timeLimitSec Int           @default(20)
  basePoints   Int           @default(1000)
  choices      Choice[]
  answers      PlayerAnswer[]

  @@unique([quizId, order])
}

model Choice {
  id         String         @id @default(cuid())
  questionId String
  question   Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int
  text       String
  isCorrect  Boolean        @default(false)
  answers    PlayerAnswer[]

  @@unique([questionId, order])
}

model Story {
  id           String   @id @default(cuid())
  title        String
  description  String?
  icon         String?
  difficulty   String?
  /// How many trailing words the current writer can see (1 = only the previous word).
  visibleWords Int      @default(1)
  /// Optional word count at which the story auto-ends. Null = host stops manually.
  targetWords  Int?
  /// Optional per-turn time limit in seconds. When it runs out the turn is
  /// skipped to the next player. Null = players have unlimited time.
  turnSeconds  Int?
  createdAt    DateTime @default(now())
  games        Game[]
}

model Game {
  id                   String     @id @default(cuid())
  pin                  String     @unique
  kind                 GameKind   @default(QUIZ)
  quizId               String?
  quiz                 Quiz?      @relation(fields: [quizId], references: [id])
  storyId              String?
  story                Story?     @relation(fields: [storyId], references: [id])
  status               GameStatus @default(LOBBY)
  currentQuestionIndex Int        @default(-1)
  questionStartedAt    DateTime?
  /// STORY: the player whose turn it is to add the next word.
  currentTurnPlayerId  String?
  /// STORY: when the current turn began (drives the per-turn timer).
  turnStartedAt        DateTime?
  stateVersion         Int        @default(0)
  hostToken            String
  createdAt            DateTime   @default(now())
  players              Player[]
  answers              PlayerAnswer[]
  storyWords           StoryWord[]

  @@index([status])
}

model StoryWord {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  order     Int
  text      String
  createdAt DateTime @default(now())

  @@unique([gameId, order])
  @@index([gameId])
}

model Player {
  id       String         @id @default(cuid())
  gameId   String
  game     Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  nickname String
  emoji    String
  score    Int            @default(0)
  joinedAt DateTime       @default(now())
  lastSeen DateTime       @default(now())
  answers  PlayerAnswer[]
  storyWords StoryWord[]

  @@unique([gameId, nickname])
  @@index([gameId])
}

model PlayerAnswer {
  id            String   @id @default(cuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choiceId      String
  choice        Choice   @relation(fields: [choiceId], references: [id])
  answeredAt    DateTime @default(now())
  isCorrect     Boolean
  pointsAwarded Int
  responseMs    Int

  @@unique([playerId, questionId])
  @@index([gameId, questionId])
}
