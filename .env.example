# --- Database (Neon in production) ---

# App runtime: use Neon's POOLED connection string (host contains "-pooler").
# Serverless + SSE opens many short-lived connections, so pooling is required.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Migrations only: Neon's DIRECT (unpooled) string — same host WITHOUT "-pooler".
# PgBouncer transaction pooling can't run Prisma migrations.
DIRECT_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"
